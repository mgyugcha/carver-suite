{
  "name": "carvers-suite",
  "version": "1.1.0",
  "description": "Suite de carvers de recuperación de información",
  "author": "Michael Yugcha <mgyugcha@gmail.com>",
  "homepage": "https://gitlab.com/mgyugcha/carvers-suite",
  "private": true,
  "main": "main.js",
  "build": {
    "appId": "me.mgyugcha.carvers-suite",
    "directories": {
      "buildResources": "static"
    },
    "linux": {
      "category": "Utility",
      "synopsis": "Suite de carvers de recuperación de información",
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icons/png/",
      "desktop": {
        "Name": "Carvers Suite",
        "Icon": "carvers-suite",
        "Comment": "Suite de carvers de recuperación de información",
        "Categories": "Utility"
      }
    },
    "deb": {
      "depends": [
        "ffmpeg",
        "unoconv",
        "foremost",
        "scalpel"
      ]
    }
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=DEV electron .",
    "build": "nuxt build && electron-builder",
    "rebuild": "electron-rebuild -w sqlite3 -p",
    "lint": "eslint --ext .js,.vue --ignore-path .gitignore ."
  },
  "dependencies": {
    "@nuxtjs/axios": "^5.4.1",
    "awesome-unoconv": "^1.0.1",
    "bayes-server": "^8.1.0",
    "bluebird": "^3.5.3",
    "body-parser": "^1.18.3",
    "bufferutil": "^4.0.1",
    "command-exists": "^1.2.8",
    "docxtemplater": "^3.9.9",
    "drivelist": "^7.0.1",
    "express": "^4.16.4",
    "ffmpeg": "0.0.4",
    "file-type": "^10.8.0",
    "get-port-sync": "^1.0.0",
    "hypernal": "^0.3.0",
    "imagemagick": "^0.1.3",
    "jszip": "^2.6.1",
    "moment": "^2.24.0",
    "nuxt": "^2.7.1",
    "nuxt-buefy": "^0.3.4",
    "pdf-parse": "^1.1.1",
    "read-chunk": "^3.0.0",
    "recursive-readdir": "^2.2.2",
    "socket.io": "^2.2.0",
    "sqlite3": "^4.0.6",
    "utf-8-validate": "^5.0.2",
    "vue-google-charts": "^0.3.2"
  },
  "devDependencies": {
    "@nuxtjs/eslint-config": "0.0.1",
    "babel-eslint": "^10.0.1",
    "cross-env": "^5.1.4",
    "electron": "4.1.1",
    "electron-builder": "^20.5.1",
    "electron-devtools-installer": "^2.2.3",
    "electron-rebuild": "^1.8.4",
    "eslint": "^5.15.1",
    "eslint-config-standard": "^12.0.0",
    "eslint-friendly-formatter": "^4.0.1",
    "eslint-loader": "^2.1.2",
    "eslint-plugin-import": "^2.16.0",
    "eslint-plugin-jest": "^22.3.2",
    "eslint-plugin-node": "^8.0.1",
    "eslint-plugin-promise": "^4.0.1",
    "eslint-plugin-standard": "^4.0.0",
    "eslint-plugin-vue": "^5.2.2"
  }
}
